{% style %}
  .section-{{ section.id }} {
    background-color: {{ section.settings.section_bg_color }};
    padding-top: {{ section.settings.desktop_padding_top }}px;
    padding-bottom: {{ section.settings.desktop_padding_bottom }}px;
    overflow: hidden;
  }

  .section-{{ section.id }} .titanium-wrapper {
    position: relative;
    border-radius: 20px;
    background: #FFF;
    padding: 40px 20px;
    display: flex;
    flex-direction: column;
    gap: 50px;
  }

  .section-{{ section.id }} .titanium-head {
    text-align: center;
  }

  .section-{{ section.id }} .titanium-tag {
    margin-bottom: 24px;
    color: {{ section.settings.tag_text_color }};
  }

  .section-{{ section.id }} .titanium-title {
    text-align: center;
    font-family: "Faculty Glyphic";
    font-size: 48px;
    font-style: normal;
    font-weight: var(--font-weight-300, 400);
    line-height: 60px;
    text-transform: capitalize;
    color: {{ section.settings.heading_color }};
  }

  .section-{{ section.id }} .titanium-subtitle {
    color: {{ section.settings.text_color }};
    margin: 0;
    text-align: center;
    font-family: "Suisse Int'l";
    font-size: 18px;
    font-style: normal;
    font-weight: 450;
    line-height: 24px;
    padding-block: 12px;
  }

  .section-{{ section.id }} .titanium-blocks {
    display: grid;
    grid-template-columns: 1fr minmax(300px, 450px) 1fr;
    gap: 14px;
    align-items: center;
  }

  .section-{{ section.id }} .titanium-blocks_left,
  .section-{{ section.id }} .titanium-blocks_right {
    display: flex;
    flex-direction: column;
    gap: 14px;
    height: stretch;
    justify-content: space-between;
  }

  .section-{{ section.id }} .titanium-block {
    background-color: {{ section.settings.block_bg_color }};
    border-radius: 8px;
    padding: 20px 28px;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .section-{{ section.id }} .block__left {
    text-align: right;
  }

  .section-{{ section.id }} .block__right {
    text-align: left;
  }

  .section-{{ section.id }} .titanium-block-icon {
    width: 80px;
    height: 80px;
    margin-bottom: 12px;
  }

  .section-{{ section.id }} .block__left .titanium-block-icon {
    margin-left: auto;
  }

  .section-{{ section.id }} .block__right .titanium-block-icon {
    margin-right: auto;
  }

  .section-{{ section.id }} .titanium-block-icon img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
  }

  .section-{{ section.id }} .titanium-block-title {
    color: {{ section.settings.block_heading_color }};
    margin: 0 0 10px;
    text-align: right;
    font-family: "Suisse Int'l";
    font-size: 18px;
    font-style: normal;
    font-weight: 700;
    line-height: 22px;
    text-transform: capitalize;
  }

  .section-{{ section.id }} .block__right .titanium-block-title,
  .section-{{ section.id }} .block__right .titanium-block-subtext{
        text-align: left;
    }

  .section-{{ section.id }} .titanium-block-subtext {
    color: {{ section.settings.block_text_color }};
    margin: 0;
    color: #000000;
    color: #000;
    text-align: right;
    font-family: "Suisse Int'l";
    font-size: 18px;
    font-style: normal;
    font-weight: 400;
    line-height: 22px;
  }

  .section-{{ section.id }} .titanium-wrapper-main_image {
    position: relative;
    border-radius: 8px;
    overflow: hidden;
  }

  .section-{{ section.id }} .titanium-wrapper-main_image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  @media screen and (max-width: 768px) {
    .section-{{ section.id }} {
      padding-top: {{ section.settings.mobile_padding_top }}px;
      padding-bottom: {{ section.settings.mobile_padding_bottom }}px;
    }

    .section-{{ section.id }} .titanium-subtitle {
        font-size: 14px;
        line-height: 20px;
        font-weight: 300;
        padding: 5px 0 0;
    }

    .section-{{ section.id }} .titanium-wrapper {
        gap: 31px;
        padding: 30px 12px 12px;
    }

    .section-{{ section.id }} .titanium-blocks {
      grid-template-columns: 1fr;
      gap: 11px;
    }

    .section-{{ section.id }} .titanium-blocks_left, 
    .section-{{ section.id }} .titanium-blocks_right {
        gap: 11px;
    }

    .section-{{ section.id }} .titanium-block {
        padding: 20px 12px;
        text-align: left;
        gap: 12px;
        flex-direction: row;
        align-items: center;
    }

    .section-{{ section.id }} .titanium-block-icon {
        width: 60px;
        height: 60px;
        margin: 0;
    }

    .section-{{ section.id }} .titanium-title {
        font-size: 28px !important;
        line-height: 37px !important;
        letter-spacing: -0.9px !important;
    }

    .section-{{ section.id }} .titanium-tag {
        margin-bottom: 10px;
    }

    .section-{{ section.id }} .titanium-block-title {
        font-size: 16px;
        text-align: left;
        margin-bottom: 5px;
    }

    .section-{{ section.id }} .titanium-block-subtext {
        text-align: left;
        font-size: 14px;
        line-height: 20px;
    }

    .section-{{ section.id }} .block__right .titanium-block-icon {
        margin-right: unset !important;
    }

    .section-{{ section.id }} .titanium-block-text {
        flex: 1 !important;
    }

    .titanium-wrapper-main_image_desk{
      display: none !important;
    }

    .titanium-wrapper-main_image_mob{
      display: block !important;
    }

  }
{% endstyle %}

<section class="titanium-section section-{{ section.id }}">
  <div class="page-width">
    <div class="titanium-wrapper">

      <div class="titanium-head">

        {% if section.settings.tag_text != blank %}
          <div class="titanium-tag tag_tag">

            {% if section.settings.tag_icon != blank %}
              <div class="tag_icon">
                {{
                  section.settings.tag_icon
                  | image_url: width: 100
                  | image_tag:
                    widths: '50,100',
                    loading: 'lazy',
                    alt: 'tag icon'
                }}
              </div>
            {% endif %}

            {{ section.settings.tag_text }}

          </div>
        {% endif %}

        {% if section.settings.heading != blank %}
          <h2 class="titanium-title title_title">
            {{
              section.settings.heading
              | replace: '<p>', ''
              | replace: '</p>', ''
            }}
          </h2>
        {% endif %}

        {% if section.settings.subtitle != blank %}
          <div class="titanium-subtitle">
            {{ section.settings.subtitle }}
          </div>
        {% endif %}

      </div>

      <div class="titanium-blocks">

        <div class="titanium-blocks_left">
          {% for block in section.blocks %}
            {% if block.settings.block_position == 'left' %}
              <div
                class="titanium-block block__left"
                {{ block.shopify_attributes }}
              >

                {% if block.settings.icon != blank %}
                  <div class="titanium-block-icon">
                    {{
                      block.settings.icon
                      | image_url: width: 200
                      | image_tag:
                        widths: '50,100,150,200',
                        loading: 'lazy',
                        alt: block.settings.title
                    }}
                  </div>
                {% endif %}

                <div class="titanium-block-text">
                    {% if block.settings.title != blank %}
                      <h3 class="titanium-block-title">
                        {{
                          block.settings.title
                          | replace: '<p>', ''
                          | replace: '</p>', ''
                        }}
                      </h3>
                    {% endif %}
    
                    {% if block.settings.text != blank %}
                      <div class="titanium-block-subtext">
                        {{ block.settings.text }}
                      </div>
                    {% endif %}
                </div>


              </div>
            {% endif %}
          {% endfor %}
        </div>

        <div class="titanium-wrapper-main_image">

          {% if section.settings.main_image != blank %}
            {{
              section.settings.main_image
              | image_url: width: 1200
              | image_tag:
                widths: '200,300,400,500,600,700,800,900,1000,1200',
                loading: 'lazy',
                alt: 'main image',
                class: 'titanium-wrapper-main_image_desk'
            }}
            {{
              section.settings.main_image_mob
              | image_url: width: 1200
              | image_tag:
                widths: '200,300,400,500,600,700,800,900,1000,1200',
                loading: 'lazy',
                alt: 'main image',
                class: 'titanium-wrapper-main_image_mob',
                style: 'display: none;'
            }}
          {% endif %}

        </div>

        <div class="titanium-blocks_right">
          {% for block in section.blocks %}
            {% if block.settings.block_position == 'right' %}
              <div
                class="titanium-block block__right"
                {{ block.shopify_attributes }}
              >

                {% if block.settings.icon != blank %}
                  <div class="titanium-block-icon">
                    {{
                      block.settings.icon
                      | image_url: width: 200
                      | image_tag:
                        widths: '50,100,150,200',
                        loading: 'lazy',
                        alt: block.settings.title
                    }}
                  </div>
                {% endif %}

                <div class="titanium-block-text">
                    {% if block.settings.title != blank %}
                      <h3 class="titanium-block-title">
                        {{
                          block.settings.title
                          | replace: '<p>', ''
                          | replace: '</p>', ''
                        }}
                      </h3>
                    {% endif %}
    
                    {% if block.settings.text != blank %}
                      <div class="titanium-block-subtext">
                        {{ block.settings.text }}
                      </div>
                    {% endif %}
                </div>

              </div>
            {% endif %}
          {% endfor %}
        </div>

      </div>

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Titanium Features",
  "settings": [
    {
      "type": "text",
      "id": "tag_text",
      "label": "Tag Text",
      "default": "Why Choose Us"
    },
    {
      "type": "image_picker",
      "id": "tag_icon",
      "label": "Tag Icon"
    },
    {
      "type": "richtext",
      "id": "heading",
      "label": "Heading",
      "default": "<p>Premium Titanium Features</p>"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle"
    },
    {
      "type": "image_picker",
      "id": "main_image",
      "label": "Main Image"
    },
    {
      "type": "image_picker",
      "id": "main_image_mob",
      "label": "Main Image Mobile"
    },
    {
      "type": "color",
      "id": "section_bg_color",
      "label": "Section Background Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Subtitle Color",
      "default": "#555555"
    },
    {
      "type": "color",
      "id": "tag_text_color",
      "label": "Tag Text Color",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "block_bg_color",
      "label": "Block Background Color",
      "default": "#f5f5f5"
    },
    {
      "type": "color",
      "id": "block_heading_color",
      "label": "Block Heading Color",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "block_text_color",
      "label": "Block Text Color",
      "default": "#555555"
    },
    {
      "type": "range",
      "id": "desktop_padding_top",
      "label": "Desktop Padding Top",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "desktop_padding_bottom",
      "label": "Desktop Padding Bottom",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "mobile_padding_top",
      "label": "Mobile Padding Top",
      "min": 0,
      "max": 120,
      "step": 2,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "mobile_padding_bottom",
      "label": "Mobile Padding Bottom",
      "min": 0,
      "max": 120,
      "step": 2,
      "unit": "px",
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "feature_block",
      "name": "Feature Block",
      "settings": [
        {
          "type": "select",
          "id": "block_position",
          "label": "Block Position",
          "default": "left",
          "options": [
            {
              "value": "left",
              "label": "Left"
            },
            {
              "value": "right",
              "label": "Right"
            }
          ]
        },
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Titanium Features",
      "category": "Custom",
      "blocks": [
        {
          "type": "feature_block"
        },
        {
          "type": "feature_block",
          "settings": {
            "block_position": "right"
          }
        }
      ]
    }
  ]
}
{% endschema %}