{% style %}
  .section-{{ section.id }} {
    background: {{ section.settings.section_bg }};
    padding-top: {{ section.settings.desktop_padding_top }}px;
    padding-bottom: {{ section.settings.desktop_padding_bottom }}px;
  }

  .section-{{ section.id }} .contact-card-wrapper {
    width: 100%;
  }

  .section-{{ section.id }} .contact-card__cards {
    display: grid;
    grid-template-columns: repeat({{ section.settings.columns_desktop }}, 1fr);
    gap: 16px;
  }

  .section-{{ section.id }} .contact-card__card {
    background: {{ section.settings.card_bg }};
    display: flex;
    gap: 16px;
    border-radius: 11px;
    flex-direction: column;
    align-items: center;
    padding: 11px;
  }

  .section-{{ section.id }} .contact-card__card-info {
        text-align: center;
    }

  .section-{{ section.id }} .contact-card__card-icon {
    flex-shrink: 0;
    width: 48px;
    height: 48px;
  }

  .section-{{ section.id }} .contact-card__card-icon img {
    width: 100%;
    height: 100%;
    display: block;
  }

  .section-{{ section.id }} .contact-card__card-title {
    color: {{ section.settings.title_color }};
    margin: 0 0 8px;
    text-align: center;
    font-family: "Faculty Glyphic";
    font-size: 20px;
    font-style: normal;
    font-weight: 400;
    line-height: 120%;
  }

  .section-{{ section.id }} .contact-card__card-link {
    color: {{ section.settings.link_color }};
    text-decoration: none;
    display: inline-block;
    font-family: "Suisse Int'l";
    font-size: 15px;
    font-style: normal;
    font-weight: 450;
    line-height: 120%;
  }

  @media screen and (max-width: 990px) {

    .section-{{ section.id }} {
      padding-top: {{ section.settings.mobile_padding_top }}px;
      padding-bottom: {{ section.settings.mobile_padding_bottom }}px;
    }

    .section-{{ section.id }} .contact-card__cards {
      grid-template-columns: repeat({{ section.settings.columns_mobile }}, 1fr);
      gap: 12px;
    }

    .section-{{ section.id }} .contact-card__card {
        padding: 16px;
    }

    .section-{{ section.id }} .contact-card__card-icon {
        flex-shrink: 0;
        width: 60px;
        height: 60px;
    }

    .section-{{ section.id }} .contact-card__card-title {
        font-size: 22px;
    }

  }
{% endstyle %}

<section class="contact-card-section fade-in-section section-{{ section.id }}">
  <div class="page-width">

    <div class="contact-card-wrapper">

      {% if section.blocks.size > 0 %}
        <div class="contact-card__cards">

          {% for block in section.blocks %}
            <div class="contact-card__card fade-in-item" {{ block.shopify_attributes }}>

              {% if block.settings.icon != blank %}
                <div class="contact-card__card-icon">
                  {{
                    block.settings.icon
                    | image_url: width: 200
                    | image_tag:
                      widths: '100,150,200',
                      loading: 'lazy',
                      alt: block.settings.title
                  }}
                </div>
              {% endif %}

              <div class="contact-card__card-info">

                {% if block.settings.title != blank %}
                  <h4 class="contact-card__card-title fade-in-up">
                    {{ block.settings.title }}
                  </h4>
                {% endif %}

                {% if block.settings.link_text != blank %}
                  <a
                    href="{{ block.settings.link_url }}"
                    class="contact-card__card-link fade-in-up"
                  >
                    {{ block.settings.link_text }}
                  </a>
                {% endif %}

              </div>

            </div>
          {% endfor %}

        </div>
      {% endif %}

    </div>

  </div>
</section>

{% schema %}
{
  "name": "Contact Cards",
  "settings": [
    {
      "type": "color_background",
      "id": "section_bg",
      "label": "Section Background",
      "default": "#ffffff"
    },
    {
      "type": "color_background",
      "id": "card_bg",
      "label": "Card Background",
      "default": "#f5f5f5"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title Color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "link_color",
      "label": "Link Color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "Desktop Columns",
      "min": 1,
      "max": 4,
      "step": 1,
      "default": 3
    },
    {
      "type": "range",
      "id": "columns_mobile",
      "label": "Mobile Columns",
      "min": 1,
      "max": 3,
      "step": 1,
      "default": 1
    },
    {
      "type": "range",
      "id": "desktop_padding_top",
      "label": "Desktop Padding Top",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "desktop_padding_bottom",
      "label": "Desktop Padding Bottom",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "mobile_padding_top",
      "label": "Mobile Padding Top",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "mobile_padding_bottom",
      "label": "Mobile Padding Bottom",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "default": 32
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title"
        },
        {
          "type": "text",
          "id": "link_text",
          "label": "Link Text"
        },
        {
          "type": "url",
          "id": "link_url",
          "label": "Link URL"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Contact Cards",
      "blocks": [
        {
          "type": "card"
        },
        {
          "type": "card"
        },
        {
          "type": "card"
        }
      ]
    }
  ]
}
{% endschema %}