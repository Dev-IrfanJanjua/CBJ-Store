{% liquid
  assign image_position = section.settings.image_position
%}

{% style %}
  .section-{{ section.id }} {
    background: {{ section.settings.section_bg }};
    padding-top: {{ section.settings.desktop_padding_top }}px;
    padding-bottom: {{ section.settings.desktop_padding_bottom }}px;
  }

  .section-{{ section.id }} .img-text-wrapper {
    display: flex;
    align-items: stretch;
    gap: 20px;
  }

  .section-{{ section.id }} .img-text-wrapper.image-right {
    flex-direction: row;
  }

  .section-{{ section.id }} .img-text-wrapper.image-left {
    flex-direction: row-reverse;
  }

  .section-{{ section.id }} .img-text__content,
  .section-{{ section.id }} .img-text__image {
    max-width: calc(50% - 10px);
    width: 100%;
    border-radius: 20px;
    overflow: hidden;
  }

  .section-{{ section.id }} .img-text__content {
    background: {{ section.settings.content_bg }};
    padding: 32px 23px;
  }

  .section-{{ section.id }} .img-text__description {
    --scroll-progress: 0%;
    color: {{ section.settings.description_color }};
    font-family: "Suisse Int'l";
    font-size: clamp(20px, 1.81vw, 26px);
    font-style: normal;
    font-weight: 450;
    line-height: 139%;
    background: linear-gradient(
        to right,
        {{ section.settings.description_color_strng }} var(--scroll-progress),
        {{ section.settings.description_color }} var(--scroll-progress)
    );

    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;

    display: inline;
  }

  .section-{{ section.id }} .img-text-tag {
    color: {{ section.settings.tag_color }};
    margin-bottom: 20px;
  }

  .section-{{ section.id }} .img-text__image {
    width: 100%;
    height: auto;
    display: block;
  }

  .section-{{ section.id }} .img-text__image img{
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
  }

  @media screen and (max-width: 990px) {

    .section-{{ section.id }} {
      padding-top: {{ section.settings.mobile_padding_top }}px;
      padding-bottom: {{ section.settings.mobile_padding_bottom }}px;
    }

    .section-{{ section.id }} .img-text-wrapper,
    .section-{{ section.id }} .img-text-wrapper.image-left,
    .section-{{ section.id }} .img-text-wrapper.image-right {
      flex-direction: column-reverse;
      gap: 14px;
    }

    .section-{{ section.id }} .img-text__image{
        aspect-ratio: 9/10;
    }

    .section-{{ section.id }} .img-text__content,
    .section-{{ section.id }} .img-text__image {
      max-width: 100%;
    }
  }
{% endstyle %}

<section class="img-text-section fade-in-section section-{{ section.id }}">
  <div class="page-width">

    <div class="img-text-wrapper fade-in-item image-{{ image_position }}">

      <div class="img-text__content">

        {% if section.settings.tag_text != blank %}
          <div class="img-text-tag tag_tag fade-in-up">
            <div class="tag_icon">
                {{
                    section.settings.tag_icon
                    | image_url: width: 1200
                    | image_tag:
                    widths: '400,600,800,1000,1200',
                    loading: 'lazy',
                    alt: section.settings.image.alt
                }}
            </div>
            {{ section.settings.tag_text }}
          </div>
        {% endif %}

        {% if section.settings.description != blank %}
            <div>
                <div class="img-text__description fade-in-up">
                  {{ section.settings.description | replace: '<p>', '' | replace: '</p>', '' }}
                </div>
            </div>
        {% endif %}

      </div>

      <div class="img-text__image fade-in-item">

        {% if section.settings.image != blank %}
          {{
            section.settings.image
            | image_url: width: 1200
            | image_tag:
              widths: '400,600,800,1000,1200',
              loading: 'eager',
              alt: section.settings.image.alt
          }}
        {% endif %}

      </div>

    </div>

  </div>
</section>

<script>
document.addEventListener('DOMContentLoaded', function () {

  const text = document.querySelector('.section-{{ section.id }} .img-text__description');

  if (!text) return;

  function updateScrollReveal() {

    const rect = text.getBoundingClientRect();
    const windowHeight = window.innerHeight;

    // let progress = 1 - (rect.bottom / (windowHeight + rect.height));
    // progress = Math.max(0, Math.min(progress, 1));

    let progress = 1 - (rect.bottom / (windowHeight + 1.3));
    progress = progress * 1.4;

    text.style.setProperty(
      '--scroll-progress',
      `${progress * 100}%`
    );
  }

  updateScrollReveal();

  window.addEventListener('scroll', updateScrollReveal, {
    passive: true
  });

});
</script>

{% schema %}
{
  "name": "Image Text Section",
  "settings": [
    {
      "type": "image_picker",
      "id": "tag_icon",
      "label": "Tag Icon"
    },
    {
      "type": "text",
      "id": "tag_text",
      "label": "Tag Text"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Image Position",
      "default": "right",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ]
    },
    {
      "type": "color_background",
      "id": "section_bg",
      "label": "Section Background",
      "default": "#ffffff"
    },
    {
      "type": "color_background",
      "id": "content_bg",
      "label": "Content Background",
      "default": "transparent"
    },
    {
      "type": "color",
      "id": "description_color",
      "label": "Description Color",
      "default": "#717171"
    },
    {
      "type": "color",
      "id": "description_color_strng",
      "label": "Description Color Strong",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "tag_color",
      "label": "Tag Text Color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "desktop_padding_top",
      "label": "Desktop Padding Top",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "desktop_padding_bottom",
      "label": "Desktop Padding Bottom",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "mobile_padding_top",
      "label": "Mobile Padding Top",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "mobile_padding_bottom",
      "label": "Mobile Padding Bottom",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "default": 32
    }
  ],
  "presets": [
    {
      "name": "Image Text Section"
    }
  ]
}
{% endschema %}