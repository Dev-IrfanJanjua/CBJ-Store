{% comment %} === search form show script === {% endcomment %}

<script>
document.addEventListener("DOMContentLoaded", function () {

    const searchIcon = document.querySelector(".cstm_search-icon");
    const searchBox = document.querySelector(".header__search");
    const closeBtn = document.querySelector(".header__search-close");
    const overlay = document.querySelector(".fixed-overlay");

    if (!searchIcon || !searchBox) return;

    // OPEN SEARCH
    function openSearch() {
        searchBox.classList.add("active");
        document.body.classList.add("search-open");
    }

    // CLOSE SEARCH
    function closeSearch() {
        searchBox.classList.remove("active");
        document.body.classList.remove("search-open");
    }

    // TOGGLE
    searchIcon.addEventListener("click", function (e) {
        e.stopPropagation();

        if (searchBox.classList.contains("active")) {
            closeSearch();
        } else {
            openSearch();
        }
    });

    // CLOSE BUTTON
    if (closeBtn) {
        closeBtn.addEventListener("click", function (e) {
            e.stopPropagation();
            closeSearch();
        });
    }

    // OVERLAY CLICK
    if (overlay) {
        overlay.addEventListener("click", function () {
            closeSearch();
        });
    }

    // PREVENT INSIDE CLICK
    searchBox.addEventListener("click", function (e) {
        e.stopPropagation();
    });

    // OUTSIDE CLICK
    document.addEventListener("click", function () {
        closeSearch();
    });

});
</script>

