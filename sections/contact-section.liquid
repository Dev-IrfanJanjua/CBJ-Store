{% style %}
  .section-{{ section.id }} {
    background: {{ section.settings.section_bg }};
    padding-top: {{ section.settings.desktop_padding_top }}px;
    padding-bottom: {{ section.settings.desktop_padding_bottom }}px;
  }

  .section-{{ section.id }} .cbj-contact-wrapper {
    display: flex;
    gap: 20px;
    align-items: stretch;
  }

  .section-{{ section.id }} .cbj-contact-image {
    border-radius: 10px;
    overflow: hidden;
    height: auto;
    max-width: calc(100% - (52% + 20px));
    width: 100%;
  }

  .section-{{ section.id }} .cbj-contact-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .section-{{ section.id }} .cbj-contact-form-wrapper {
    background: {{ section.settings.form_bg }};
    border-radius: 10px;
    padding: 24px;
    max-width: 52%;
    width: 100%;
  }

  .section-{{ section.id }} .cbj-contact-title {
    color: {{ section.settings.heading_color }};
    margin: 0 0 24px;
    font-family: "Faculty Glyphic";
    font-size: 28px;
    font-style: normal;
    font-weight: 400;
    line-height: 120%;
    letter-spacing: -0.56px;
  }

  .section-{{ section.id }} .cbj-contact-form-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px 12px;
  }

  .section-{{ section.id }} .cbj-field {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .section-{{ section.id }} .cbj-field.full-width {
    grid-column: span 2;
  }

  .section-{{ section.id }} .cbj-field label {
    color: {{ section.settings.label_color }};
    margin: 0;
    font-family: "Suisse Int'l";
    font-size: 18px;
    font-style: normal;
    font-weight: 450;
    line-height: normal;
    letter-spacing: -0.72px;
  }

  .section-{{ section.id }} #ContactFormName-{{ section.id }}{
    text-transform: capitalize;
  }

  .section-{{ section.id }} .cbj-field input,
  .section-{{ section.id }} .cbj-field textarea,
  .section-{{ section.id }} .cbj-field select {
    background: {{ section.settings.field_bg }};
    color: {{ section.settings.input_color }};
    width: 100%;
    border: none;
    outline: none;
    padding: 12px;
    border-radius: 6px;
    appearance: none;
    font-family: "Suisse Int'l";
    font-size: 14px;
    font-style: normal;
    font-weight: 300;
    line-height: 120%;
    letter-spacing: -0.42px;
    min-height: 50px;
  }

  .section-{{ section.id }} .cbj-field select{
    cursor: pointer;
  }

  .section-{{ section.id }} .cbj-field textarea {
    min-height: 210px;
    resize: none;
  }

  .section-{{ section.id }} .cbj-field input::placeholder,
  .section-{{ section.id }} .cbj-field textarea::placeholder {
    color: {{ section.settings.placeholder_color }};
  }

  .section-{{ section.id }} .cbj-select-wrapper {
    position: relative;
  }

  .section-{{ section.id }} .cbj-select-icon {
    position: absolute;
    top: 50%;
    right: 16px;
    transform: translateY(-50%);
    pointer-events: none;
    width: 12px;
    height: 12px;
  }

  .section-{{ section.id }} .cbj-select-icon img {
    width: 100%;
    height: 100%;
    display: block;
  }

  .section-{{ section.id }} .cbj-contact-btn {
    background: {{ section.settings.button_bg }};
    color: {{ section.settings.button_text_color }};
    width: 100%;
    border: none;
    cursor: pointer;
    border-radius: 100px;
    padding: 16px 30px;
    margin-top: 28px;
    transition: 0.3s ease;
    font-family: "Faculty Glyphic";
    font-size: 18px;
    font-style: normal;
    font-weight: 400;
    line-height: 148%;
    text-transform: uppercase;
    min-height: 60px;
  }

  .section-{{ section.id }} .cbj-contact-btn:hover {
    opacity: 0.85;
  }

  .section-{{ section.id }} .form-status {
    margin: 0 0 20px;
    color: var(--Black, #111);
    font-family: "Suisse Int'l";
    font-size: 16px;
    font-style: normal;
    font-weight: 450;
    line-height: normal;
    letter-spacing: -0.72px;
  }

  @media screen and (max-width: 990px) {

    .section-{{ section.id }} {
      padding-top: {{ section.settings.mobile_padding_top }}px;
      padding-bottom: {{ section.settings.mobile_padding_bottom }}px;
    }

    .section-{{ section.id }} .cbj-contact-wrapper {
        flex-direction: column;
        gap: 14px;
    }

    .section-{{ section.id }} .cbj-contact-form-grid {
      grid-template-columns: 1fr;
      gap: 12px;
    }

    .section-{{ section.id }} .cbj-field.full-width {
      grid-column: span 1;
    }

    .section-{{ section.id }} .cbj-contact-image {
        max-width: 100%;
        aspect-ratio: 9/10;
    }

    .section-{{ section.id }} .cbj-contact-form-wrapper {
        max-width: 100%;
    }

  }
{% endstyle %}

<section class="cbj-contact-section fade-in-section section-{{ section.id }}">
  <div class="page-width">
    <div class="cbj-contact-wrapper">
      <div class="cbj-contact-image fade-in-item">
        {% if section.settings.image != blank %}
          {{
            section.settings.image
            | image_url: width: 1200
            | image_tag: widths: '400,600,800,1000,1200', loading: 'lazy', alt: 'contact image'
          }}
        {% endif %}
      </div>

      <div class="cbj-contact-form-wrapper fade-in-item">
        {% if section.settings.heading != blank %}
          <h2 class="cbj-contact-title fade-in-left">
            {{ section.settings.heading }}
          </h2>
        {% endif %}

        {% form 'contact' %}
          {% if form.posted_successfully? %}
            <div class="form-status form-status-list form__message fade-in-up">
              {{ 'templates.contact.form.post_success' | t }}
            </div>
          {% endif %}

          {{ form.errors | default_errors }}

          <div class="cbj-contact-form-grid">
            <div class="cbj-field fade-in-item">
              <label for="ContactFormName-{{ section.id }}"> Name </label>

              <input
                id="ContactFormName-{{ section.id }}"
                type="text"
                name="contact[name]"
                placeholder="Enter Your Name"
                value="{{ form.name }}"
                autocomplete="name"
                required
              >
            </div>

            <div class="cbj-field fade-in-item">
              <label for="ContactFormEmail-{{ section.id }}"> Email </label>

              <input
                id="ContactFormEmail-{{ section.id }}"
                type="email"
                name="contact[email]"
                placeholder="Enter Your Email"
                value="{{ form.email }}"
                autocomplete="email"
                autocorrect="off"
                autocapitalize="off"
                required
                aria-required="true"
              >
            </div>

            <div class="cbj-field fade-in-item">
              <label for="ContactFormPhone-{{ section.id }}"> Phone Number </label>

              <input
                id="ContactFormPhone-{{ section.id }}"
                type="tel"
                name="contact[phone]"
                placeholder="Phone Number"
                value="{{ form.phone }}"
                autocomplete="tel"
              >
            </div>

            <div class="cbj-field fade-in-item">
              <label for="ContactFormSubject-{{ section.id }}"> Subject </label>

              <div class="cbj-select-wrapper">
                <select
                    id="ContactFormSubject-{{ section.id }}"
                    name="contact[Subject]"
                    required
                    >

                    <option
                        value=""
                        selected
                        disabled
                        hidden
                    >
                        Select Subject
                    </option>

                    {% if section.blocks.size > 0 %}
                        {% for block in section.blocks %}
                        {% if block.settings.subject_text != blank %}
                            <option value="{{ block.settings.subject_text }}">
                            {{ block.settings.subject_text }}
                            </option>
                        {% endif %}
                        {% endfor %}
                    {% endif %}

                    </select>

                <div class="cbj-select-icon">
                  {% if section.settings.select_icon != blank %}
                    {{
                      section.settings.select_icon
                      | image_url: width: 50
                      | image_tag: widths: '20,30,40,50', loading: 'lazy', alt: 'Select icon'
                    }}
                  {% endif %}
                </div>
              </div>
            </div>

            <div class="cbj-field full-width fade-in-item">
              <label for="ContactFormMessage-{{ section.id }}"> Message </label>

              <textarea
                id="ContactFormMessage-{{ section.id }}"
                name="contact[body]"
                placeholder="Write Your Message Here..."
                rows="10"
              >{{ form.body }}</textarea>
            </div>
          </div>

          <button
            type="submit"
            class="cbj-contact-btn fade-in-item"
          >
            {{ section.settings.button_text }}
          </button>
        {% endform %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "CBJ Contact Section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Contact Image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Send Us a Message"
    },
    {
      "type": "image_picker",
      "id": "select_icon",
      "label": "Select Icon"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "SUBMIT"
    },
    {
      "type": "color_background",
      "id": "section_bg",
      "label": "Section Background",
      "default": "#ffffff"
    },
    {
      "type": "color_background",
      "id": "form_bg",
      "label": "Form Background",
      "default": "#f5f5f5"
    },
    {
      "type": "color_background",
      "id": "field_bg",
      "label": "Field Background",
      "default": "#ebebeb"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "label_color",
      "label": "Label Color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "input_color",
      "label": "Input Text Color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "placeholder_color",
      "label": "Placeholder Color",
      "default": "#8f8f8f"
    },
    {
      "type": "color_background",
      "id": "button_bg",
      "label": "Button Background",
      "default": "#221815"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button Text Color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "desktop_padding_top",
      "label": "Desktop Padding Top",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "desktop_padding_bottom",
      "label": "Desktop Padding Bottom",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "mobile_padding_top",
      "label": "Mobile Padding Top",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "mobile_padding_bottom",
      "label": "Mobile Padding Bottom",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "default": 32
    }
  ],
  "blocks": [
    {
      "type": "subject",
      "name": "Subject Option",
      "settings": [
        {
          "type": "text",
          "id": "subject_text",
          "label": "Subject Text"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "CBJ Contact Section",
      "category": "Custom",
      "blocks": [
        {
          "type": "subject"
        },
        {
          "type": "subject"
        },
        {
          "type": "subject"
        }
      ]
    }
  ]
}
{% endschema %}
