    background: #000;
    border-radius: 20px;
    overflow: hidden;
    max-height: 100%;
    z-index: 100;
}

.vp-video {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  cursor: pointer;
}

.vp-close {
    position: absolute;
    top: 12px;
    right: 12px;
    z-index: 101;
    background: rgba(0,0,0,0.6);
    border: none;
