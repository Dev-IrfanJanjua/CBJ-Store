.vp-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.7);
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 14px 14px 20px;
}

.vp-modal {
    position: relative;
    width: 100%;
    max-width: 700px;
