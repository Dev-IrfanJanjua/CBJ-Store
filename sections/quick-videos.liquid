<script>
(function () {
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }

  function init() {
    // ── Swiper ──
    new Swiper('.mySwiper-{{ section.id }}', {
      navigation: {
        nextEl: '.button-next-{{ section.id }}',
        prevEl: '.button-prev-{{ section.id }}',
      },
      slidesPerView: 1.1,
      spaceBetween: 6,
      speed: 1000,
      breakpoints: {
        0:    { slidesPerView: 1.1, spaceBetween: 6 },
        768:  { slidesPerView: 2.2, spaceBetween: 8 },
        1024: { slidesPerView: 3.4, spaceBetween: 8 },
      }
    });

    // ── Popup elements ──
    var overlay  = document.getElementById('vpOverlay-{{ section.id }}');
    var popVideo = document.getElementById('vpVideo-{{ section.id }}');
    var closeBtn = document.getElementById('vpClose-{{ section.id }}');

    // ── Click on any slide card → open popup ──
    var containers = document.querySelectorAll(
      '.mySwiper-{{ section.id }} .vedio-container'
    );

    containers.forEach(function (card) {
      card.style.cursor = 'pointer';
      card.addEventListener('click', function () {
        // Get the <video> inside this card
        var inlineVideo = card.querySelector('video');
        if (!inlineVideo) return;

        // Copy the video source into the popup player
        var src = inlineVideo.currentSrc || inlineVideo.src;
        if (!src && inlineVideo.querySelector('source')) {
          src = inlineVideo.querySelector('source').src;
        }

        popVideo.src = src;
        overlay.style.display = 'flex';
        popVideo.play();
      });
    });

    // ── Close popup ──
    function closePopup() {
      popVideo.pause();
      popVideo.src = '';
      overlay.style.display = 'none';
    }

    closeBtn.addEventListener('click', closePopup);

    // Click outside modal also closes
    overlay.addEventListener('click', function (e) {
      if (e.target === overlay) closePopup();
    });

    // ESC key closes
    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape' && overlay.style.display === 'flex') {
        closePopup();
      }
    });
  }
})();
</script>

{% schema %}
{
  "name": "trust by Name",
  "settings": [
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding Top",
      "default": 10
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 10
    },
    {
      "type": "range",
      "id": "mbl_padding_top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Mobile Top Padding",
      "default": 10
    },
    {
      "type": "range",
      "id": "mbl_padding_bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Mobile Bottom Padding",
      "default": 10
    },
    {
      "type": "color",
      "id": "back_color",
      "label": "Background Color"
    },
    {
      "type": "image_picker",
      "id": "eye_icon",
      "label": "Eye Icon"
    },
    {
      "type": "richtext",
      "id": "head_text",
      "label": "Heading Text"
    },
    {
      "type": "textarea",
      "id": "des_text",
      "label": "Description Text",
      "default": "Your description goes here."
    },
    {
      "type": "image_picker",
      "id": "prev",
      "label": "Previous Slider Image"
    },
    {
      "type": "image_picker",
      "id": "next",
      "label": "Next Slider Image"
    },
    {
       "type":"checkbox",
       "id": "pdp",
       "label": "Pdp Styling"
    }

  ],
  "blocks": [
    {
      "type": "block",
      "name": "Block",
      "settings": [
        {
          "type": "image_picker",
          "id": "f_img",
          "label": "Feature Image"
        },
        {
          "type": "text",
          "id": "f_text",
          "label": "Feature Text",
          "default": "Feature description"
        },
        {
          "type": "video",
          "id": "video",
          "label": "Video"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "trust by Name"
    }
  ]
}
{% endschema %}