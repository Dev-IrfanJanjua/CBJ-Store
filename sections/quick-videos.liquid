<section class="trust-by fade-in-section section-{{ section.id }}-padding {% if section.settings.pdp %}pdp-video{% endif %} pdp-section" id="trust">
  <div class="page-width">
    <div class="trust-by-wrapper">
        <div class="top-sec">
          {% if section.settings.head_text %}
            <div class="live-heading fade-in-up csp-img">{{ section.settings.head_text | replace: '<p>', '' |replace: '</p>', '' }}</div>
          {% endif %}
          {% if section.settings.des_text %}
            <div class="des-text fade-in-up csp-img">{{ section.settings.des_text }}</div>
          {% endif %}
        </div>
        <div class="bottom-sec csp-img">
          <div class="swiper mySwiper-{{ section.id }}">
            <div class="swiper-wrapper">
              {% for block in section.blocks %}
                <div class="swiper-slide" data-slide-index="{{ forloop.index0 }}">
                  <div class="vedio-container fade-in-item" data-video-index="{{ forloop.index0 }}">
                    {% comment %} {% render 'play' %} {% endcomment %}
                     {% comment %} {% if section.settings.eye_icon != blank %} {% endcomment %}
                         <div class="video_slider-eye-icon">
                            {{ section.settings.eye_icon 
                                | image_url: width: 100 
                                | image_tag:
                                widths: '50, 100',
                                alt: section.settings.eye_icon.alt | default: "Eye Icon",
                                loading: "lazy",
                                class: "eye-icon-img"
                            }}
                         </div>
                     {% comment %} {% endif %} {% endcomment %}
                    {% if block.settings.video != blank %}
                     {% assign video_poster = section.settings.video.preview_image | image_url: width: 1200 %}
                      {{
                          block.settings.video
                          | video_tag:
                            class: 'dental-video-slider',
                            autoplay: true,
                            loop: true,
                            controls: false,
                            playsinline: true,
                            poster: video_poster,
                            muted:true,
                            preload: 'auto'
                        }}
                    {% endif %}
                  </div>
                 
                </div>
              {% endfor %}
            </div>
            <div class="main-btnn">
              <div class="button-next-{{ section.id }} swip__btnn swip__btn-next">
                  <img class="swip-img-c" src="{{ section.settings.next | image_url }}" width="50" height="50" alt="pause" data-action="pause">
              </div>
              <div class="button-prev-{{ section.id }} swip__btnn swip__btn-prev">
                  <img class="swip-img-c" src="{{ section.settings.prev | image_url }}" width="50" height="50" alt="pause" data-action="pause">
              </div>
            </div>
          </div>
        </div>
    </div>
  </div>

</section>

<!-- VIDEO POPUP -->
    <div class="vp-overlay" id="vpOverlay-{{ section.id }}" style="display:none;">
