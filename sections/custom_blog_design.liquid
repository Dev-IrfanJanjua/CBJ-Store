<style>
body.article-template { background: #ffffff; } 
body.article-template .breadcrumbs a.reversed-link { color: #555555; } 
body.article-template span.breadcrumbs--sep { background: #aaaaaa; transform: rotate(15deg); } 
body.article-template span.breadcrumbs--last.text-subtext { color: #111111; }
.blog_flex{display:flex;justify-content:space-between;gap:30px;margin-top:30px}
.blog_post_left{width:75%}
.blog_post_right{width:25%}
body.article-template{background:#ffffff}
.top_title_read_time{display:flex;gap:10px;align-items:center}
.top_title_read_time h6.blog_main_title{background:#f0eeff;color:#6b46c1;text-transform:uppercase;padding:5px 10px;border:1px solid #6b46c1;border-radius:50px;font-size:14px}
.read_time{color:#444444}
h2.blog_main_title{font-size:50px;color:#111111}
.why_shop_camden{background:#f3f4f6;border:1px solid #e0e0e0;border-radius:20px;padding:30px 25px;color:#111111}
h2.why_shop_head_main{color:#111111;font-size:24px}
.blog_post_right .why_shop_camden ul li{display:flex;gap:12px}
.blog_post_right .why_shop_camden ul{margin-top:20px}
.blog_post_right .shop_data h5{color:#111111}
.blog_post_right .shop_data p{margin:0}
.blog_post_right .shop_list img{width:34px;height:34px;padding-top:5px}
.blog_post_right .why_shop_camden ul{display:flex;flex-direction:column;gap:15px}
.blog_trending_prod .trending_head{display:flex;align-items:center;justify-content:space-between}
