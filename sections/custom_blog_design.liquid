                        </div>
                    </div>
                </div>
          {% endcase %}
        {% endfor %}
      </div>

      <div class="blog_post_right">
        {% for block in section.blocks %}

        {% case block.type %}
          
          {% when 'shop_feature' %}
          <div class="why_shop_camden">
            <h2 class="why_shop_head_main">{{ block.settings.why_shop_head }}</h2>
            <ul>

              <li>
                {% if block.settings.shop_list_img_1 %}
                <div class="shop_list">
                  <img src="{{ block.settings.shop_list_img_1 | img_url: 'master' }}" alt="">
                </div>
                {% endif %}
                <div class="shop_data">
                  <h5>{{ block.settings.shop_data_head_1 }}</h5>
                  <p>{{ block.settings.shop_data_subhead_1 }}</p>
