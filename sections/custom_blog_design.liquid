<div class="custom_blog_design">
  <div class="page-width">

    <div class="top_title_read_time">
       <h6 class="blog_main_title">{{ article.title }}</h6> 
       <div class="read_time">5 min read</div>
    </div>

    <div class="blog_flex">
      <div class="blog_post_left">
        <div class="blog_content">{{ article.content }}</div>       
        {% for block in section.blocks %}
          {% case block.type %}          
          {% comment %} {% when 'common_causes' %}
                <div class="common_causes">
                    <h3><span>?</span>{{ block.settings.comm_cuas_head }}</h3>

                    {% if block.settings.quest_data_1 %}
                    <div class="question_data">
                          {{ block.settings.quest_data_1 }}  
                          {% comment %} <div class="most_comm_tag"></div> {% endcomment %}
                    </div>
                    {% endif %}

                    {% if block.settings.quest_data_2 %}
                    <div class="question_data">
                          {{ block.settings.quest_data_2 }}  
                    </div>
                    {% endif %}

                    {% if block.settings.quest_data_3 %}
                    <div class="question_data">
                          {{ block.settings.quest_data_3 }}  
                    </div>
                    {% endif %}

                    {% if block.settings.quest_data_4 %}
                    <div class="question_data">
                          {{ block.settings.quest_data_4 }}  
                    </div>
                    {% endif %}

                    {% if block.settings.quest_data_5 %}
                    <div class="question_data">
                          {{ block.settings.quest_data_5 }}  
                    </div>
                    {% endif %}
                </div> {% endcomment %}


            {% when 'Shop_Hypoallergenic' %}
                <div class="shop_hypoallergenic">
                      <h4>{{ block.settings.shop_hy_head }} </h4> 
                      <div class="shop_sbtxtx">{{ block.settings.shop_sbxt }}</div>
                      <div class="shop_hyp_btn">
                        <a href="{{ block.settings.shop_hyp_btn_link }}">{{ block.settings.shop_hyp_btn_title }}</a>
                      </div>
                </div>

            {% when 'myths_vs_reality' %}
                <div class="myths_reality">
                    <h3>{{ block.settings.myth_real_head }}</h3>
                    <div class="myths_flex">
