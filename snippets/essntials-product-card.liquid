{% liquid
  assign current_product = product_item
%}

<div class="pdp-essential-card">

    {% assign hover_image = current_product.images[1] | default: current_product.featured_image %}
    <a
        href="{{ current_product.url }}"
        class="pdp-essential-image"
    >
        {% if current_product.featured_image != blank %}

            {{
            current_product.featured_image
            | image_url: width: 500
            | image_tag:
                class: 'pdp-essential-primary-image',
                loading: 'lazy',
                widths: '120,180,250,350,500',
                alt: current_product.title
            }}

            {{
            hover_image
            | image_url: width: 500
            | image_tag:
                class: 'pdp-essential-hover-image',
                loading: 'lazy',
                widths: '120,180,250,350,500',
                alt: current_product.title
            }}

        {% endif %}

    </a>

  <div class="pdp-essential-content">

    <h4 class="pdp-essential-title">
      <a href="{{ current_product.url }}">
        {{ current_product.title }}
      </a>
    </h4>

    <div class="pdp-essential-footer">

      <span class="pdp-essential-price">
        {{ current_product.price | money }}
      </span>

      <div class="pdp-essential-atc">
        {% render 'buy-buttons',
          product: current_product,
          block: block,
          product_form_id: product_form_id,
          section_id: section.id,
          section: section
        %}
      </div>

    </div>

  </div>

</div>

{% style %}

.pdp-essential-card {
    border-radius: 12px;
    background: #F6F6F6;
    padding: 8px;
    display: flex;
    flex-direction: column;
    gap: 14px;
    width: 100%;
}

a.pdp-essential-image {
  position: relative;
  display: block;
  width: 100%;
  height: 162px;
  border-radius: 6px;
  overflow: hidden;
  background: #fff;
}

a.pdp-essential-image img {
  position: absolute;
  inset: 0;

  width: 100%;
  height: 100%;
  display: block;
  object-fit: cover;

  backface-visibility: hidden;
  -webkit-backface-visibility: hidden;

  transition:
    opacity 0.45s ease,
    transform 0.6s ease;
}

/* Base states */
.pdp-essential-primary-image {
  opacity: 1;
  z-index: 1;
}

.pdp-essential-hover-image {
  opacity: 0;
  z-index: 2;
}

/* Hover */
@media (hover: hover) and (pointer: fine) {

  .pdp-essential-image:hover .pdp-essential-hover-image {
    opacity: 1;
    transform: scale(1.03);
  }

  .pdp-essential-image:hover .pdp-essential-primary-image {
    opacity: 0;
    transform: scale(1.03);
  }

}

h4.pdp-essential-title a,
h4.pdp-essential-title {
    color: #000;
    font-family: "Faculty Glyphic";
    font-size: 14px;
    font-style: normal;
    font-weight: 400;
    line-height: normal;
    min-height: 55px;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;

    overflow: hidden;
    text-overflow: ellipsis;
}

span.pdp-essential-price, 
span.pdp-essential-price span.money {
    color: #1A1A1A;
    font-family: "Suisse Int'l";
    font-size: 12px;
    font-style: normal;
    font-weight: 450;
    line-height: 120%;
}

.pdp-essential-footer {
    display: flex;
    align-items: center;
    gap: 10px;
    justify-content: space-between;
    margin-top: 8px;
}

.pdp-essential-atc .product-form__submit {
    background: transparent;
    padding: 0;
    width: fit-content;
    height: fit-content;
    border-radius: 0;
    border: none;
    overflow: visible;
}

span.pdp-essential-atc_icon {
    width: 16px;
    height: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
}

span.pdp-essential-atc_icon svg{
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
}

@media screen and (max-width: 768px){

    a.pdp-essential-image{
        height: 150px;
    }

}

{% endstyle %}