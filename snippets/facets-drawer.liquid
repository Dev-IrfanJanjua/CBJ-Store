{%- liquid
  assign active_values_count = 0

  for filter in results.filters
    if filter.type == 'price_range'
      if filter.max_value.value != blank or filter.min_value.value != blank
        assign active_values_count = active_values_count | plus: 1
      endif
    else
      for active_value in filter.active_values
        assign active_values_count = active_values_count | plus: 1
      endfor
    endif
  endfor
-%}
<div class="facet-drawer-wrapper no-js-hidden">
  {%- if filter_type == 'vertical' -%}
    <div class="hidden xl:flex">
      <button
        is="facet-toggler"
        type="button"
        class="btn btn--icon gap-2 facet-drawer-button no-js-hidden"
      >
        <span class="btn__text flex gap-1 items-center">
          {%- render 'icon-funnel', size: 'large' -%}
          <span>{{ 'products.facets.filter_button' | t }}</span>
        </span>
      </button>
    </div>
  {%- endif -%}
  <div class="facet-drawer-button-wrap{% if filter_type == 'vertical' %} flex xl:hidden{% endif %}">
    <button
      class="btn btn--secondary gap-2 facet-drawer-button"
      type="button"
      aria-controls="FacetDrawer"
      aria-expanded="false"
      data-facet-loading
    >
      <span class="btn__text flex gap-1 items-center">
        {% comment %} {%- render 'icon-funnel', size: 'large' -%} {% endcomment %}
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 18 18" fill="none">
          <path d="M16.2546 8.95894H6.26673M2.74127 8.95894H1.29907M2.74127 8.95894C2.74127 8.49154 2.92694 8.04329 3.25744 7.71279C3.58794 7.38229 4.0362 7.19661 4.5036 7.19661C4.971 7.19661 5.41925 7.38229 5.74975 7.71279C6.08025 8.04329 6.26593 8.49154 6.26593 8.95894C6.26593 9.42634 6.08025 9.87459 5.74975 10.2051C5.41925 10.5356 4.971 10.7213 4.5036 10.7213C4.0362 10.7213 3.58794 10.5356 3.25744 10.2051C2.92694 9.87459 2.74127 9.42634 2.74127 8.95894ZM16.2546 14.3001H11.6079M11.6079 14.3001C11.6079 14.7676 11.4218 15.2164 11.0912 15.5469C10.7606 15.8775 10.3122 16.0632 9.84474 16.0632C9.37735 16.0632 8.92909 15.8767 8.59859 15.5462C8.26809 15.2157 8.08242 14.7675 8.08242 14.3001M11.6079 14.3001C11.6079 13.8326 11.4218 13.3846 11.0912 13.0541C10.7606 12.7235 10.3122 12.5378 9.84474 12.5378C9.37735 12.5378 8.92909 12.7234 8.59859 13.0539C8.26809 13.3844 8.08242 13.8327 8.08242 14.3001M8.08242 14.3001H1.29907M16.2546 3.6178H13.7445M10.219 3.6178H1.29907M10.219 3.6178C10.219 3.1504 10.4047 2.70214 10.7352 2.37164C11.0657 2.04114 11.514 1.85547 11.9814 1.85547C12.2128 1.85547 12.442 1.90105 12.6558 1.98962C12.8696 2.07818 13.0639 2.208 13.2275 2.37164C13.3912 2.53529 13.521 2.72957 13.6095 2.94338C13.6981 3.1572 13.7437 3.38636 13.7437 3.6178C13.7437 3.84923 13.6981 4.07839 13.6095 4.29221C13.521 4.50603 13.3912 4.7003 13.2275 4.86395C13.0639 5.0276 12.8696 5.15741 12.6558 5.24597C12.442 5.33454 12.2128 5.38012 11.9814 5.38012C11.514 5.38012 11.0657 5.19445 10.7352 4.86395C10.4047 4.53345 10.219 4.08519 10.219 3.6178Z" stroke="white" stroke-width="1.21261" stroke-miterlimit="10" stroke-linecap="round"/>
        </svg>
        {{ 'products.facets.filter_button' | t }}
        <facet-count
          {% if active_values_count == 0 %}
            hidden
          {% endif %}
          >({{ active_values_count }})</facet-count
        >
      </span>
      {%- render 'loading-spinner', size: 'small' -%}
    </button>
  </div>
  <drawer-component id="FacetDrawer" role="dialog" class="drawer drawer--left facet-drawer" hidden>
    <div class="fixed-overlay" aria-controls="FacetDrawer"></div>
    <div class="drawer__inner color-{{ settings.overlay_color_scheme }}">
      <div class="drawer__content flex flex-col h-full w-full">
        <div class="drawer__header facet-drawer__header">
          <div class="drawer__header-inner flex items-center justify-between gap-3">
            <h2 class="drawer__heading h4">
              <span>{{ 'products.facets.filter_button' | t }}</span>
            </h2>
            <button
              class="drawer__close-btn z-1"
              aria-controls="FacetDrawer"
              aria-label="{{ 'accessibility.close' | t }}"
              type="button"
            >
              {% render 'icon-close', size: 'large' %}
            </button>
          </div>
        </div>
        <div class="drawer__body flex-grow v-scrollable" id="DrawerFacetFiltersContainer">
          {%- if enable_sorting -%}
            <div class="flex items-center gap-3 lg:hidden facet-short-drawer" id="SortByContainerMobile">
              {%- render 'facet-short', results: results, label_class: 'h4', context: 'drawer' -%}
            </div>
          {%- endif -%}
          {%- render 'facets', context: 'drawer', results: results -%}
          <div class="drawer__sticky drawer__sticky--bottom w-full z-1 background-1">
            <button class="btn btn--primary w-full" type="button" aria-controls="FacetDrawer" aria-expanded="false">
              <span class="btn__text">
                {{ 'products.facets.apply' | t }}
                <facet-count
                  {% if active_values_count == 0 %}
                    hidden
                  {% endif %}
                  >({{ active_values_count }})</facet-count
                >
              </span>
            </button>
          </div>
        </div>
      </div>
    </div>
  </drawer-component>
</div>
