{% comment %}
  Dynamic Free Shipping Bar - Absolute Position Fix
  Threshold: £40.00
{% endcomment %}

<div class="cbj-shipping-widget" data-threshold="4000">
  
  <!-- Message -->
  <div class="cbj-text-wrapper">
    <p class="cbj-msg">Checking cart...</p>
  </div>

  <!-- Progress Bar -->
  <div class="cbj-track">
    <div class="cbj-fill" style="width: 0%;"></div>
  </div>

</div>

<style>
  /* --- CONTAINER --- */
  .cbj-shipping-widget {
    margin: 15px 0 25px 0;
    width: 100%;
    display: block;
    box-sizing: border-box;
  }

  /* --- TEXT --- */
  .cbj-text-wrapper {
    margin-bottom: 8px;
    text-align: left;
  }

  .cbj-msg {
    margin: 0 !important;
    font-size: 14px;
    font-weight: 500;
    color: #333;
    line-height: 1.4;
  }
  
  .cbj-msg strong {
    color: #1d349a;
  }

  /* --- TRACK (Grey Background) --- */
  .cbj-track {
    width: 100%;
    height: 10px;
    background-color: #E5E5E5;
    border-radius: 10px;
    position: relative;
    overflow: hidden;
    z-index: 1;
  }

  /* --- FILL (Blue Bar) --- */
  .cbj-fill {
    position: absolute;
    top: 0;
    left: 0;
    bottom: 0;
    height: 100%;
    background-color: #1d349a;
    width: 0%;
    border-radius: 10px;
    transition: width 0.4s ease-out;
    z-index: 2;
    display: block !important;
  }
  
  /* --- SUCCESS STATE --- */
  .cbj-shipping-widget.success .cbj-msg {
    color: #008a4e;
  }
  .cbj-shipping-widget.success .cbj-fill {
    background-color: #00b67a;
    width: 100% !important;
  }
</style>

<script>
(function() {
  const THRESHOLD = 4000; // £40.00

  function updateBar() {
    fetch(window.Shopify.routes.root + 'cart.js')
      .then(res => res.json())
      .then(cart => {
        const total = cart.total_price;
        
        let percent = (total / THRESHOLD) * 100;
        if (percent > 100) percent = 100;
        if (total > 0 && percent < 5) percent = 5; 

        const remaining = (THRESHOLD - total) / 100;

        document.querySelectorAll('.cbj-shipping-widget').forEach(widget => {
          const fill = widget.querySelector('.cbj-fill');
          const msg = widget.querySelector('.cbj-msg');

          if (!fill || !msg) return;

          fill.setAttribute('style', 'width:' + percent + '% !important');

          if (total >= THRESHOLD) {
            widget.classList.add('success');
            msg.innerHTML = "🎉 You've unlocked <strong>Free UK Delivery</strong>!";
          } else {
            widget.classList.remove('success');
            msg.innerHTML = `Spend <strong>£${remaining.toFixed(2)}</strong> more for Free Delivery`;
          }
        });
      })
      .catch(e => console.error(e));
  }

  updateBar();

  const originalFetch = window.fetch;
  window.fetch = function() {
    return originalFetch.apply(this, arguments).then((response) => {
      if (response.url.includes('/cart/')) {
        setTimeout(updateBar, 500);
      }
      return response;
    });
  };
})();
</script>