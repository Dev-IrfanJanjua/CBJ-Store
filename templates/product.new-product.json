        "custom_liquid_FhdQGV": {
          "type": "custom_liquid",
          "disabled": true,
          "settings": {
            "custom_liquid": "<style>\n  /* Unlock Savings — gamified multi-buy tiers */\n  .unlock-savings {\n    margin: 16px 0 20px;\n    padding: 16px;\n    background: #FFF4EB;\n    border-radius: 14px;\n    position: relative;\n  }\n\n  .unlock-savings__header {\n    display: flex;\n    align-items: center;\n    justify-content: space-between;\n    gap: 8px;\n    margin-bottom: 12px;\n  }\n\n  .unlock-savings__title {\n    display: flex;\n    align-items: center;\n    gap: 8px;\n    font-size: 13px;\n    font-weight: 700;\n    color: #001116;\n    text-transform: uppercase;\n    letter-spacing: 0.08em;\n    margin: 0;\n  }\n\n  .unlock-savings__title-icon {\n    width: 16px;\n    height: 16px;\n    display: inline-flex;\n    align-items: center;\n    justify-content: center;\n  }\n\n  .unlock-savings__status {\n    font-size: 11px;\n    font-weight: 600;\n    color: #001116;\n    opacity: 0.7;\n  }\n\n  .unlock-savings__tiers {\n    display: flex;\n    flex-direction: column;\n    gap: 8px;\n  }\n\n  .unlock-tier {\n    display: flex;\n    align-items: center;\n    justify-content: space-between;\n    gap: 12px;\n    padding: 12px 16px;\n    background: #FFD8C2;\n    border-radius: 10px;\n    position: relative;\n    overflow: hidden;\n    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);\n  }\n\n  .unlock-tier__left {\n    display: flex;\n    align-items: center;\n    gap: 10px;\n    position: relative;\n    z-index: 1;\n  }\n\n  .unlock-tier__marker {\n    width: 22px;\n    height: 22px;\n    border-radius: 50%;\n    background: #FFF4EB;\n    border: 2px solid #001116;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    flex-shrink: 0;\n    transition: all 0.4s ease;\n  }\n\n  .unlock-tier__marker svg {\n    width: 12px;\n    height: 12px;\n    color: #001116;\n    opacity: 0;\n    transform: scale(0.5);\n    transition: all 0.3s ease 0.1s;\n  }\n\n  .unlock-tier__text {\n    font-size: 14px;\n    font-weight: 600;\n    color: #001116;\n    letter-spacing: -0.01em;\n  }\n\n  .unlock-tier__save {\n    font-size: 14px;\n    font-weight: 700;\n    color: #001116;\n    position: relative;\n    z-index: 1;\n  }\n\n  /* Unlocked state */\n  .unlock-tier--unlocked {\n    background: #001116;\n  }\n  .unlock-tier--unlocked .unlock-tier__marker {\n    background: #001116;\n    border-color: #FBFAF9;\n  }\n  .unlock-tier--unlocked .unlock-tier__marker svg {\n    color: #FBFAF9;\n    opacity: 1;\n    transform: scale(1);\n  }\n  .unlock-tier--unlocked .unlock-tier__text,\n  .unlock-tier--unlocked .unlock-tier__save {\n    color: #FBFAF9;\n  }\n\n  /* Next-to-unlock hint */\n  .unlock-tier--next {\n    box-shadow: 0 0 0 2px #001116;\n  }\n\n  /* Pair badge above */\n  .cbj-pair-badge {\n    display: inline-flex;\n    align-items: center;\n    gap: 6px;\n    padding: 6px 12px;\n    background: #FFF4EB;\n    border-radius: 999px;\n    font-size: 11px;\n    font-weight: 700;\n    color: #001116;\n    text-transform: uppercase;\n    letter-spacing: 0.08em;\n    margin-bottom: 8px;\n  }\n  .cbj-pair-badge__icon { font-size: 12px; }\n  .cbj-pair-note {\n    font-size: 13px;\n    color: #001116;\n    opacity: 0.75;\n    margin: 0 0 16px;\n    line-height: 1.5;\n  }\n\n  @media (max-width: 480px) {\n    .unlock-tier__text { font-size: 13px; }\n    .unlock-tier__save { font-size: 13px; }\n  }\n</style>\n\n<div class=\"cbj-pair-badge\">\n  <span class=\"cbj-pair-badge__icon\">✨</span>Sold as a Pair\n</div>\n<p class=\"cbj-pair-note\">Every piece on Camden Body Jewellery is sold as a matching pair — you'll receive two items per unit.</p>\n\n<div class=\"unlock-savings\" data-unlock-savings>\n  <div class=\"unlock-savings__header\">\n    <p class=\"unlock-savings__title\">\n      <span class=\"unlock-savings__title-icon\">\n        <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><rect x=\"3\" y=\"11\" width=\"18\" height=\"11\" rx=\"2\"/><path d=\"M7 11V7a5 5 0 0 1 9.9-1\"/></svg>\n      </span>\n      Unlock Savings\n    </p>\n    <span class=\"unlock-savings__status\" data-unlock-status>Add items to unlock</span>\n  </div>\n\n  <div class=\"unlock-savings__tiers\">\n    <div class=\"unlock-tier\" data-threshold=\"2\">\n      <div class=\"unlock-tier__left\">\n        <span class=\"unlock-tier__marker\">\n          <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"3\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><polyline points=\"20 6 9 17 4 12\"/></svg>\n        </span>\n        <span class=\"unlock-tier__text\">Buy any 2 items</span>\n      </div>\n      <span class=\"unlock-tier__save\">Save 25%</span>\n    </div>\n\n    <div class=\"unlock-tier\" data-threshold=\"3\">\n      <div class=\"unlock-tier__left\">\n        <span class=\"unlock-tier__marker\">\n          <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"3\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><polyline points=\"20 6 9 17 4 12\"/></svg>\n        </span>\n        <span class=\"unlock-tier__text\">Buy any 3+ items</span>\n      </div>\n      <span class=\"unlock-tier__save\">Save 40%</span>\n    </div>\n  </div>\n</div>\n\n<script>\n(function() {\n  if (window.unlockSavingsLoaded) return;\n  window.unlockSavingsLoaded = true;\n\n  function updateUnlockSavings() {\n    fetch('/cart.js')\n      .then(r => r.json())\n      .then(cart => {\n        const count = cart.item_count;\n        const wrappers = document.querySelectorAll('[data-unlock-savings]');\n\n        wrappers.forEach(wrapper => {\n          const tiers = wrapper.querySelectorAll('.unlock-tier');\n          const statusEl = wrapper.querySelector('[data-unlock-status]');\n          let highestUnlocked = 0;\n          let nextTier = null;\n\n          tiers.forEach(tier => {\n            const threshold = parseInt(tier.getAttribute('data-threshold'), 10);\n            tier.classList.remove('unlock-tier--next');\n            if (count >= threshold) {\n              tier.classList.add('unlock-tier--unlocked');\n              if (threshold > highestUnlocked) highestUnlocked = threshold;\n            } else {\n              tier.classList.remove('unlock-tier--unlocked');\n              if (!nextTier) nextTier = { el: tier, threshold };\n            }\n          });\n\n          if (nextTier) nextTier.el.classList.add('unlock-tier--next');\n\n          if (statusEl) {\n            if (count === 0) {\n              statusEl.textContent = 'Add items to unlock';\n            } else if (nextTier) {\n              const needed = nextTier.threshold - count;\n              const discount = nextTier.threshold === 2 ? '25%' : '40%';\n              statusEl.textContent = needed === 1\n                ? `Add 1 more for ${discount} off`\n                : `Add ${needed} more for ${discount} off`;\n            } else {\n              statusEl.textContent = '🎉 Max saving unlocked';\n            }\n          }\n        });\n      })\n      .catch(() => {});\n  }\n\n  document.addEventListener('DOMContentLoaded', updateUnlockSavings);\n  updateUnlockSavings();\n\n  const origFetch = window.fetch;\n  window.fetch = function() {\n    return origFetch.apply(this, arguments).then(response => {\n      const url = response.url || '';\n      if (url.includes('/cart/add') || url.includes('/cart/change') || url.includes('/cart/update') || url.includes('/cart/clear')) {\n        setTimeout(updateUnlockSavings, 400);\n      }\n      return response;\n    });\n  };\n})();\n</script>"
          }
        },
